# Pexip One Touch Join (OTJ) -- server-side only, used by /api/meetings route
# Get these from your Pexip OTJ portal
PEXIP_OTJ_AUTH_URL=https://auth.otj.pexip.io
PEXIP_OTJ_API_URL=https://otj.pexip.io
PEXIP_OTJ_CLIENT_ID=
PEXIP_OTJ_CLIENT_SECRET=

# Pexip Customer ID -- used for Teams CVI dial strings (server-side only)
PEXIP_CUSTOMER_ID=

# Provider detection domains -- used to recognize meeting aliases and build Google Meet dial strings.
# NEXT_PUBLIC_GOOGLE_DOMAIN also serves as the Google Meet CVI gateway for outbound calls.
NEXT_PUBLIC_GOOGLE_DOMAIN=
NEXT_PUBLIC_TEAMS_DOMAIN=
NEXT_PUBLIC_PEXIP_DOMAIN=

# Transcription Agent (optional) -- WebSocket-based live transcription service
# NEXT_PUBLIC_TRANSCRIPTION_API_URL=http://your-transcription-server:3000

# Supabase (Phase 2, optional)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional dev defaults -- pre-populate Settings and Setup Wizard on first launch.
# Users can always override via the in-app Settings modal.
# NEXT_PUBLIC_DEFAULT_NODE_DOMAIN=
# NEXT_PUBLIC_DEFAULT_DISPLAY_NAME=
# NEXT_PUBLIC_DEFAULT_OTJ_CLIENT_ID=
# NEXT_PUBLIC_DEFAULT_OTJ_CLIENT_SECRET=
# NEXT_PUBLIC_DEFAULT_PEXIP_CUSTOMER_ID=
# NEXT_PUBLIC_DEFAULT_REG_ALIAS=
# NEXT_PUBLIC_DEFAULT_REG_USERNAME=
# NEXT_PUBLIC_DEFAULT_REG_PASSWORD=
