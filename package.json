{
  "name": "fuse-video-client",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --port 3002",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "electron:dev": "electron .",
    "electron:build": "next build && node scripts/prepare-electron.js && electron-builder",
    "electron:pack": "next build && node scripts/prepare-electron.js && electron-builder --dir",
    "download-models": "bash scripts/download-models.sh"
  },
  "dependencies": {
    "framer-motion": "^12.34.4",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7"
  },
  "optionalDependencies": {
    "sherpa-onnx-node": "^1.12.35"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.fuse.videoclient",
    "productName": "Fuse Video Client",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      "package.json",
      "!node_modules",
      "!src",
      "!models"
    ],
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**/*"
    ],
    "compression": "maximum",
    "extraResources": [
      {
        "from": "models",
        "to": "models",
        "filter": ["**/*.onnx", "**/*.txt"]
      },
      {
        "from": "scripts/download-models.sh",
        "to": "scripts/download-models.sh"
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        "dmg"
      ],
      "darkModeSupport": true,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "Fuse Video Client needs camera access for video calls.",
        "NSMicrophoneUsageDescription": "Fuse Video Client needs microphone access for audio calls."
      }
    },
    "dmg": {
      "title": "Fuse Video Client"
    }
  }
}
